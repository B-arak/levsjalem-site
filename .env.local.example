# העתק את הקובץ הזה ל-.env.local וערוך את הערכים
# .env.local לא נכלל ב-git ולא נדחף לשרת ההפקה — שם יוגדרו משתני הסביבה ידנית

# === Grow / משולם — סליקה ===
# המפתחות זמינים ב-Grow Dashboard → API
GROW_PAGE_CODE=
GROW_API_KEY=
GROW_USER_ID=

# כתובת ה-API של Grow
# Sandbox (לפיתוח):    https://sandbox.meshulam.co.il/api/light/server/1.0/createPaymentProcess
# Production (לייצור): https://meshulam.co.il/api/light/server/1.0/createPaymentProcess
GROW_API_URL=https://sandbox.meshulam.co.il/api/light/server/1.0/createPaymentProcess

# כתובות החזרה (להחליף לפרודקשן כשעוברים לדומיין)
GROW_SUCCESS_URL=https://www.levshalem.net/thank-you
GROW_CANCEL_URL=https://www.levshalem.net/checkout?canceled=1
GROW_WEBHOOK_URL=https://www.levshalem.net/api/grow-webhook

# === מיילים ===
ORDER_NOTIFY_EMAIL=barakuty@gmail.com

# אופציונלי - לשליחת מיילים אוטומטיים. אם לא מוגדר - רק הדפסה ללוג
# הרשמה ב-https://resend.com (חינמי עד 3000 מיילים בחודש)
RESEND_API_KEY=
